# ============================================================
# docs-ready configuration
# Generated by `docs-ready init`
# Full reference: https://github.com/udhaykumarbala/docs-ready
# ============================================================

# --- Project metadata ---
title: "{{title}}"
description: "{{description}}"
url: "{{url}}"

# --- Documentation source ---
docs:
  dir: "{{docsDir}}"
  include:
    - "**/*.md"
    - "**/*.mdx"
  exclude:
    - "**/node_modules/**"
    - "**/_*"

# --- Generation ---
generate:
  llms_txt: {{llmsTxt}}
  llms_full_txt: {{llmsFullTxt}}
  ai_context: true
  output_dir: "./build"

# --- Deployment ---
deploy:
  platform: "{{platform}}"
